---
import type { CustomerProfile } from "../types/profile";
import SkipLink from "../components/shared/SkipLink.astro";
import WeThruFooter from "../components/profile/WeThruFooter.astro";
import { hasEnglish } from "../utils/i18n";
import "../styles/global.css";
import "../styles/profile-base.css";
import "../styles/themes/navy-black-white.css";
import "../styles/themes/warm-editorial.css";
import "../styles/themes/graphite-minimal.css";

interface Props {
  customer: CustomerProfile;
}

const { customer } = Astro.props;
const { seo, person, status } = customer;
const bilingual = hasEnglish(customer);

const site = Astro.site ?? new URL("https://profile.wethru.com");
const canonicalUrl = new URL(`/profiles/${customer.slug}/`, site);
const ogImageUrl = seo.ogImage ? new URL(seo.ogImage, site) : undefined;
---

<html
  lang="ko"
  data-lang="ko"
  data-effects="on"
  data-theme={customer.theme}
  data-layout={customer.layout}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Re-apply the saved interaction-effects choice before first paint so a
      // returning "off" visitor never sees hover effects flash on. Runs on
      // every profile; the default stays "on" when unset or storage is blocked.
      (function () {
        try {
          var fx = localStorage.getItem("wethru-profile-effects");
          if (fx === "on" || fx === "off") {
            document.documentElement.dataset.effects = fx;
          }
        } catch (error) {
          /* storage blocked — keep the server-rendered "on" default */
        }
      })();
    </script>
    {bilingual && (
      // Re-apply the saved language before first paint so an EN visitor
      // never sees a Korean flash. Ko-only profiles skip this entirely —
      // their data-lang stays "ko" no matter what localStorage says.
      <script is:inline>
        (function () {
          try {
            var lang = localStorage.getItem("wethru-profile-lang");
            if (lang === "en" || lang === "ko") {
              document.documentElement.dataset.lang = lang;
              document.documentElement.lang = lang;
            }
          } catch (error) {
            /* storage blocked — keep the server-rendered Korean default */
          }
        })();
      </script>
    )}
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {status === "draft" && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="profile" />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="WeThru Profile" />
    <meta property="og:locale" content="ko_KR" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <meta name="generator" content={Astro.generator} />
    <meta name="author" content={person.name} />
  </head>
  <body>
    <div class="profile-shell">
      <SkipLink />
      <main id="main" class="profile-main">
        <slot />
      </main>
      <WeThruFooter />
    </div>
  </body>
</html>
