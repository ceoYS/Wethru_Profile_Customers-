---
/**
 * SeoBaulPractice — the career as two unequal streams instead of a 2×2 card
 * grid. The wider research stream (data-center / HVAC + multimodal AI) and the
 * narrower execution stream (the venture and global work) both stay on the
 * white canvas. Green marks only the research label; a gray divider separates
 * execution. Titles and descriptions are the customer's strengths, verbatim.
 * seo-baul only.
 */
import type { ProfileStrength } from "../../types/profile";
import Bi from "../shared/Bi.astro";
import LText from "../shared/LText.astro";

interface Props {
  strengths: ProfileStrength[];
}

const { strengths } = Astro.props;
// First two strengths are the research stream; the rest are execution.
const research = strengths.slice(0, 2);
const execution = strengths.slice(2);
---

{strengths.length > 0 && (
  <section class="profile-section sb-practice" aria-labelledby="practice-title">
    <div class="section-head">
      <h2 class="section-head__title" id="practice-title">
        <Bi ko="연구와 사업" en="Research & Business" />
      </h2>
    </div>

    <div class="sb-practice__body">
      {research.length > 0 && (
        <div class="sb-practice__stream sb-practice__stream--research">
          <p class="sb-practice__stream-label sb-practice__stream-label--research">
            <Bi ko="연구" en="Research" />
          </p>
          {research.map((s) => (
            <article class="sb-practice__item">
              <h3 class="sb-practice__item-title"><LText value={s.title} /></h3>
              <p class="sb-practice__item-desc"><LText value={s.description} /></p>
            </article>
          ))}
        </div>
      )}

      {execution.length > 0 && (
        <div class="sb-practice__stream sb-practice__stream--exec">
          <p class="sb-practice__stream-label"><Bi ko="사업·실행" en="Execution" /></p>
          {execution.map((s) => (
            <article class="sb-practice__item sb-practice__item--aux">
              <h3 class="sb-practice__item-title"><LText value={s.title} /></h3>
              <p class="sb-practice__item-desc"><LText value={s.description} /></p>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
)}
