---
import type { LocalizedString } from "../../types/profile";
import LText from "../shared/LText.astro";

interface Props {
  statement: LocalizedString;
  support?: LocalizedString;
}

const { statement, support } = Astro.props;
---

<section class="profile-section profile-section--loose" aria-label="핵심 소개">
  <div class="identity">
    <span class="identity__mark" aria-hidden="true">”</span>
    <p class="identity__statement"><LText value={statement} /></p>
    {support && <p class="identity__support"><LText value={support} /></p>}
  </div>
</section>
