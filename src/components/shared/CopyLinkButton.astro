---
import Bi from "./Bi.astro";

interface Props {
  /** URL to copy. Defaults to the current page URL at click time. */
  url?: string;
  label?: string;
  labelEn?: string;
}

const {
  url,
  label = "프로필 URL",
  labelEn = "Profile URL",
} = Astro.props;
---

<button
  type="button"
  class="btn btn--ghost"
  data-copy-link
  data-copy-url={url}
  aria-label="프로필 링크를 클립보드에 복사 / Copy profile link"
>
  <Bi ko={label} en={labelEn} />
</button>

<script>
  import { initCopyLinkButtons } from "../../scripts/copy-link";
  initCopyLinkButtons();
</script>
